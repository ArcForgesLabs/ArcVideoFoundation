{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$penv{GLOBAL_VCPKG_PATH}/scripts/buildsystems/vcpkg.cmake"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "USE_WERROR": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "FASTBuild",
      "environment": {
        "PATH": "$penv{WindowsKitRC};$penv{PATH}",
        "FASTBUILD_CACHE_PATH": "$penv{LOCALAPPDATA}/FASTBuild/Cache"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "Embedded"
      },
      "vendor": {
        "arcvideo-foundation.org": {
          "vcpkgTriplet": "x64-windows"
        }
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "description": "FASTBuild Debug build",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "description": "FASTBuild Release build",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-ci",
      "displayName": "Windows x64 CI",
      "description": "CI build with warnings as errors",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "windows-vsbase",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "CMAKE_GENERATOR_TOOLSET": "ClangCL",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "Embedded"
      },
      "vendor": {
        "arcvideo-foundation.org": {
          "vcpkgTriplet": "x64-windows"
        }
      }
    },
    {
      "name": "windows-vs",
      "displayName": "Windows x64 (Visual Studio 2026)",
      "description": "Multi-config VS 2026 build (Debug and Release in one solution)",
      "inherits": ["windows-vsbase"],
      "binaryDir": "${sourceDir}/build/vs"
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "FASTBuild",
      "environment": {
        "FASTBUILD_CACHE_PATH": "/cache/fastbuild"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_HOST_TRIPLET": "x64-linux-dynamic",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "vendor": {
        "arcvideo-foundation.org": {
          "vcpkgTriplet": "x64-linux-dynamic"
        }
      }
    },
    {
      "name": "linux-ci",
      "displayName": "Linux x64 CI",
      "description": "Linux CI build with warnings as errors",
      "inherits": ["linux-base"],
      "binaryDir": "${sourceDir}/build/linux-ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "windows-debug",
      "displayName": "Debug",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "release",
      "configurePreset": "windows-release",
      "displayName": "Release",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "ci",
      "configurePreset": "windows-ci",
      "displayName": "CI",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "linux-ci",
      "configurePreset": "linux-ci",
      "displayName": "Linux CI",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    }
  ]
}
