---
# 1. Basic Settings
Language: Cpp
BasedOnStyle: Google

# 2. Modern Preferences
Standard: c++20
ColumnLimit: 120 # Optimized for modern widescreen displays
IndentWidth: 4 # 4 spaces per indent level
UseTab: Never # Disallow tabs entirely
AccessModifierOffset: -4 # Aligns public/private with class keyword when IndentWidth is 4
IndentCaseLabels: true # Indents case labels within switch statements for better hierarchy

# 3. Comment and Modifier Optimization
FixNamespaceComments: true # Automatically appends "// namespace name" to the end of namespaces
EmptyLineBeforeAccessModifier: Always # Forces an empty line before public/private/protected
BreakAfterAttributes: Leave # Allows C++ attributes like [[nodiscard]] to stay on their own line

# 4. Include Header Management (Grouping and Sorting)
SortIncludes: true
IncludeBlocks: Regroup # Automatically separates different include categories with empty lines
IncludeCategories:
  - Regex: '^"Config\.h"' # Project-specific global configuration (highest priority)
    Priority: -1
  - Regex: '^<.*\.h>' # Standard C headers (e.g., <stdio.h>)
    Priority: 1
  - Regex: "^<.*>" # Standard C++ STL headers (e.g., <vector>, <ranges>)
    Priority: 2
  - Regex: ".*" # All other custom project headers (e.g., "MyClass.h")
    Priority: 3

# 5. C++20/23 Syntax Support
AllowShortFunctionsOnASingleLine: Inline # Allows simple getters/setters on one line
AllowShortLambdasOnASingleLine: All # Keeps short lambdas on one line (useful for std::ranges calls)
LambdaBodyIndentation: Signature # Aligns lambda body with its signature for better nested formatting

# Concepts and Requires Clause Formatting
BreakBeforeConceptDeclarations: Always # Forces concept declarations onto a new line
RequiresClausePosition: OwnLine # Forces 'requires' keyword to its own line
IndentRequiresClause: true # Indents constraints after 'requires', improving readability

# 6. Style Consistency
QualifierAlignment: Left # Enforces "West Const" style (const int* instead of int const*)
PointerAlignment: Left # Aligns pointers/references to the type (int* a, int& b)
...
