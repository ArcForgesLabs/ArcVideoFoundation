{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "windows-debug"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "debug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake: Configure Release",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "windows-release"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Release",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "release"],
      "group": "build",
      "problemMatcher": "$gcc"
    }
  ]
}
