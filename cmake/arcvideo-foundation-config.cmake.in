@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Imath CONFIG REQUIRED)

# FFmpeg — locate via FindFFMPEG module (e.g. vcpkg's FindFFMPEG.cmake).
find_dependency(FFMPEG MODULE REQUIRED)
if(NOT TARGET FFMPEG::FFMPEG)
  if(DEFINED FFMPEG_LIBRARIES)
    add_library(FFMPEG::FFMPEG INTERFACE IMPORTED)
    set_target_properties(FFMPEG::FFMPEG PROPERTIES
      INTERFACE_LINK_LIBRARIES     "${FFMPEG_LIBRARIES}"
      INTERFACE_INCLUDE_DIRECTORIES "${FFMPEG_INCLUDE_DIRS}"
    )
  else()
    message(FATAL_ERROR "FFmpeg found but FFMPEG::FFMPEG target could not be created")
  endif()
endif()

# OpenTime (only when Foundation was built with OTIO support)
if(@ARCVIDEO_FOUNDATION_WITH_OTIO@)
  find_dependency(opentime CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/arcvideo-foundation-targets.cmake")

check_required_components(arcvideo-foundation)
